(defn paint [text color] (str color text RESET))

;; ---------------------------------------------------------------------
;; Terminal size
;; ---------------------------------------------------------------------

(def ^:private system-terminal
  (delay (try (-> (TerminalBuilder/builder) (.system true) (.build))
              (catch Exception _ nil))))

(defn terminal-width []
  (let [default 100]
    (or (try (when-let [cols (System/getenv "COLUMNS")]
               (let [n (Integer/parseInt (str/trim cols))]
                 (when (pos? n) n)))
             (catch Exception _ nil))
        (try (when-let [term @system-terminal]
               (let [w (.getWidth term)]
                 (when (pos? w) w)))
             (catch Exception _ nil))
        default)))

;; ---------------------------------------------------------------------
;; CLI parsing
;; ---------------------------------------------------------------------

(def long-flag->key
  {"--help" :help "--all" :include-hidden "--long" :long
   "--sort-modified" :sort-modified "--reverse" :reverse
   "--git" :git "--tree" :tree})

(def short-flag->key
  {\a :include-hidden \h :help \l :long \m :sort-modified
   \r :reverse \g :git \t :tree})

(defn parse-args [args]
  (loop [args args
         opts {:path nil :include-hidden false :sort-modified false :reverse false
               :git false :long false :tree false :help false}]
    (if (empty? args)
      (update opts :path #(or % "."))
      (let [a (first args)]
        (cond
          (contains? long-flag->key a) (recur (rest args) (assoc opts (long-flag->key a) true))
          (and (str/starts-with? a "-") (not (str/starts-with? a "--")) (> (count a) 1))
          (recur (rest args) (reduce (fn [o c] (if-let [k (short-flag->key c)] (assoc o k true) o)) opts (rest a)))
          :else (recur (rest args) (assoc opts :path a)))))))

;; ---------------------------------------------------------------------
;; Formatting helpers
;; ---------------------------------------------------------------------

(defn format-size [size]
  (let [units [["B" 1] ["KB" 1024] ["MB" 1048576] ["GB" 1073741824] ["TB" 1099511627776]]
        [uname factor] (reduce (fn [acc [_ f :as u]] (if (>= size f) u acc)) (first units) units)
        value (/ (double size) factor)
        text (if (and (< value 10.0) (not= uname "B")) (format "%.1f" value) (format "%.0f" value))]
    (str text " " uname)))

(defn- relative-unit [secs extended?]
  (cond
    (< secs 60) [secs "second"]
    (< secs 3600) [(quot secs 60) "minute"]
    (< secs 86400) [(quot secs 3600) "hour"]
    (< secs 604800) [(quot secs 86400) "day"]
    (not extended?) [(quot secs 604800) "week"]
    (< secs 2629746) [(quot secs 604800) "week"]
    (< secs 31557600) [(quot secs 2629746) "month"]
    :else [(quot secs 31557600) "year"]))

(defn format-relative-time [millis]
  (let [diff (- (System/currentTimeMillis) millis)
        past? (>= diff 0)
        secs (long (/ (Math/abs diff) 1000))
        recency (cond (not past?) :future (< secs 5) :just-now (< secs 60) :seconds
                      (< secs 3600) :minutes (< secs 86400) :hours (< secs 604800) :days
                      (< secs 2629746) :weeks (< secs 31557600) :months :else :years)]
    (if (= recency :just-now)
      ["just now" recency]
      (let [[value unit] (relative-unit secs past?)]
        [(str (if past? (str value " " unit (when (not= value 1) "s") " ago")
                  (str "in " value " " unit (when (not= value 1) "s")))) recency]))))

(defn color-modified [text recency]
  (paint text (case recency :just-now MODIFIED_RECENT :seconds MODIFIED_RECENT :minutes MODIFIED_SOON
                            :hours MODIFIED :days MODIFIED_HOURS :weeks MODIFIED_DAYS
                            :months MODIFIED_WEEKS :years MODIFIED_OLD :future MODIFIED_FUTURE MODIFIED)))

(defn color-name [name dir? exec? hidden? symlink?]
  (cond symlink? (paint name SYMLINK)
        dir? (paint name DIR)
        hidden? (paint name DOTFILE)
        exec? (paint name EXEC)
        (or (str/ends-with? name ".md") (str/ends-with? name ".toml")) (paint name WARN)
        :else (paint name FILE)))

(defn color-perm-triad [triad]
  (apply str (map #(case % \r (paint "r" PERM_R) \w (paint "w" PERM_W) \x (paint "x" PERM_X) (paint (str %) PERM_DASH)) triad)))

;; ---------------------------------------------------------------------
;; Fast NIO File Attributes
;; ---------------------------------------------------------------------

(def ^"[Ljava.nio.file.LinkOption;" no-follow-links
  (into-array LinkOption [LinkOption/NOFOLLOW_LINKS]))

(defn bulk-file-stats
  "Fetches all file metadata in a single POSIX syscall. Huge performance gain."
  [^File f]
  (let [path (.toPath f)]
    (try
      (let [attrs (Files/readAttributes path PosixFileAttributes no-follow-links)
            symlink? (.isSymbolicLink attrs)
            perms-str (PosixFilePermissions/toString (.permissions attrs))]
        {:dir? (.isDirectory attrs)
         :symlink? symlink?
         :size (.size attrs)
         :modified (.toMillis (.lastModifiedTime attrs))
         :perms perms-str
         :exec? (or (= \x (.charAt perms-str 2)) (= \x (.charAt perms-str 5)) (= \x (.charAt perms-str 8)))
         :link-target (when symlink? (try (str (Files/readSymbolicLink path)) (catch Exception _ nil)))})
      (catch Exception _
        ;; Fallback for Windows/Non-POSIX
        (let [attrs (try (Files/readAttributes path BasicFileAttributes no-follow-links) (catch Exception _ nil))
              symlink? (if attrs (.isSymbolicLink attrs) false)]
          {:dir? (if attrs (.isDirectory attrs) (.isDirectory f))
           :symlink? symlink?
           :size (if attrs (.size attrs) (.length f))
           :modified (if attrs (.toMillis (.lastModifiedTime attrs)) (.lastModified f))
           :perms (let [rwx (str (if (.canRead f) "r" "-") (if (.canWrite f) "w" "-") (if (.canExecute f) "x" "-"))] (str rwx rwx rwx))
           :exec? (.canExecute f)
           :link-target (when symlink? (try (str (Files/readSymbolicLink path)) (catch Exception _ nil)))})))))

;; ---------------------------------------------------------------------
;; Concurrent Git status
;; ---------------------------------------------------------------------

(defn git-root [dir]
  (try (let [r @(process {:dir (str dir) :out :string :err :string} "git" "rev-parse" "--show-toplevel")]
         (when (zero? (:exit r)) (str/trim (:out r)))) (catch Exception _ nil)))

(defn parse-git-status [out]
  (reduce (fn [m line]
            (if (or (str/blank? line) (str/starts-with? line "!!") (< (count line) 3)) m
                (let [code (subs line 0 2)
                      raw-path (str/trim (subs line 3))
                      path (if (str/includes? raw-path " -> ") (second (str/split raw-path #" -> " 2)) raw-path)]
                  (assoc m path {:added nil :deleted nil :dirty (not (str/blank? (str/trim code))) :untracked (= code "??")}))))
          {} (str/split-lines out)))

(defn merge-numstat [status-map out]
  (reduce (fn [m line]
            (let [parts (str/split line #"\t")]
              (if (< (count parts) 3) m
                  (let [added (try (Long/parseLong (nth parts 0)) (catch Exception _ nil))
                        deleted (try (Long/parseLong (nth parts 1)) (catch Exception _ nil))
                        path (nth parts 2)]
                    (if (and (nil? added) (nil? deleted)) m
                        (update m path (fn [existing]
                                         (if existing (-> existing (update :added #(or added %)) (update :deleted #(or deleted %)) (assoc :dirty true))
                                             {:added added :deleted deleted :dirty true :untracked false}))))))))
          status-map (str/split-lines out)))

(defn sum-opts [a b] (cond (and a b) (+ a b) a a b b :else nil))

(defn scope-git-entries [status-map root list-path]
  (let [root-path (fs/canonicalize root) list-path (fs/canonicalize list-path)
        rel-base (let [r (str (fs/relativize root-path list-path))] (if (= r ".") "" r))
        base-parts (when-not (str/blank? rel-base) (str/split rel-base #"/"))]
    (reduce (fn [scoped [path-str status]]
              (let [parts (str/split path-str #"/")
                    rel-parts (if (nil? base-parts) parts
                                  (if (and (>= (count parts) (count base-parts)) (= (take (count base-parts) parts) base-parts))
                                    (drop (count base-parts) parts) nil))]
                (if (or (nil? rel-parts) (empty? rel-parts)) scoped
                    (let [k (first rel-parts) existing (get scoped k {:added nil :deleted nil :dirty false :untracked false})]
                      (assoc scoped k {:added (sum-opts (:added existing) (:added status))
                                       :deleted (sum-opts (:deleted existing) (:deleted status))
                                       :dirty (or (:dirty existing) (:dirty status))
                                       :untracked (or (:untracked existing) (:untracked status))})))))
            {} status-map)))

(defn load-git-info [list-path]
  (when-let [root (git-root list-path)]
    ;; Kick off BOTH git subprocesses concurrently 
    (let [p-stat (process {:dir root :out :string :err :string} "git" "status" "--porcelain=1")
          p-diff (process {:dir root :out :string :err :string} "git" "diff" "--numstat" "HEAD")]
      (let [stat-res @p-stat
            diff-res @p-diff]
        (-> (if (zero? (:exit stat-res)) (parse-git-status (:out stat-res)) {})
            (merge-numstat (if (zero? (:exit diff-res)) (:out diff-res) ""))
            (scope-git-entries root list-path))))))

(defn format-git [status]
  (if (and (not (:dirty status)) (not (:untracked status)))
    ["" (paint "(clean)" GIT_CLEAN)]
    (let [added (:added status) deleted (:deleted status)
          parts (cond-> []
                  (and (:untracked status) (nil? added)) (conj ["+?" (paint "+?" GIT_ADDED)])
                  added (conj [(str "+" added) (paint (str "+" added) GIT_ADDED)])
                  deleted (conj [(str "-" deleted) (paint (str "-" deleted) GIT_REMOVED)]))
          parts (if (seq parts) parts [["dirty" (paint "dirty" GIT_DIRTY)]])]
      [(str "(" (str/join " " (map first parts)) ")") (str "(" (str/join " " (map second parts)) ")")])))

;; ---------------------------------------------------------------------
;; Collecting + sorting entries
;; ---------------------------------------------------------------------

(defn sort-rows [rows sort-modified? reverse?]
  (let [cmp (if sort-modified?
              (fn [a b] (let [c (compare (:modified-millis b) (:modified-millis a))] (if (zero? c) (compare (:sort-key a) (:sort-key b)) c)))
              (fn [a b] (cond (and (:is-dir a) (not (:is-dir b))) -1 (and (not (:is-dir a)) (:is-dir b)) 1 :else (compare (:sort-key a) (:sort-key b)))))]
    (vec (if reverse? (reverse (sort cmp rows)) (sort cmp rows)))))

(defn collect-entries [path include-hidden? sort-modified? reverse? git-info long?]
  (let [dir (File. (str path))
        files (or (.listFiles dir) (make-array File 0))
        rows (for [^File f files
                   :let [name (.getName f) hidden? (str/starts-with? name ".")]
                   :when (or include-hidden? (not hidden?))]
               (let [{:keys [dir? symlink? size modified perms exec? link-target]} (bulk-file-stats f)
                     [modified-plain recency] (format-relative-time modified)
                     name-colored (color-name name dir? exec? hidden? symlink?)
                     type-plain (cond symlink? "link" dir? "dir" :else "file")
                     [user-perm group-perm other-perm] (if long? (if (= 9 (count perms)) [(subs perms 0 3) (subs perms 3 6) (subs perms 6 9)] [perms perms perms]) ["" "" ""])
                     git-status (get git-info name)
                     [gp gc] (if git-status (format-git git-status) [nil nil])
                     has-suffix? (and gp (not (str/blank? gp)))
                     name-with-git-plain (if has-suffix? (str name " " gp) name)]
                 {:name-plain name :name-with-git-plain name-with-git-plain
                  :name-with-git-colored (if has-suffix? (str name-colored " " gc) name-colored)
                  :sort-key (str/lower-case name-with-git-plain)
                  :type-plain type-plain :type-colored (paint type-plain TYPE)
                  :user-perm-plain user-perm :user-perm-colored (color-perm-triad user-perm)
                  :group-perm-plain group-perm :group-perm-colored (color-perm-triad group-perm)
                  :other-perm-plain other-perm :other-perm-colored (color-perm-triad other-perm)
                  :link-target link-target :size-plain (format-size size) :size-colored (paint (format-size size) SIZE)
                  :modified-plain modified-plain :modified-colored (color-modified modified-plain recency)
                  :modified-millis modified :is-dir dir?}))]
    (sort-rows (vec rows) sort-modified? reverse?)))

;; ---------------------------------------------------------------------
;; Tree mode
;; ---------------------------------------------------------------------

(defn tree-entry-label [^File f include-hidden?]
  (let [name (.getName f)
        {:keys [dir? symlink? exec? link-target]} (bulk-file-stats f)
        colored (color-name name dir? exec? (str/starts-with? name ".") symlink?)]
    (if symlink? (str colored " " (paint "->" SYMLINK_ARROW) " " (paint link-target SYMLINK)) colored)))

(defn list-children [^File dir include-hidden?]
  (->> (or (.listFiles dir) (make-array File 0))
       (filter (fn [^File f] (or include-hidden? (not (str/starts-with? (.getName f) ".")))))
       (sort-by (fn [^File f] [(if (.isDirectory f) 0 1) (str/lower-case (.getName f))])) vec))

(defn print-tree [^File root include-hidden? git-info]
  (println (color-name (.getName root) true false false false))
  (letfn [(walk [^File dir prefix]
            (let [children (list-children dir include-hidden?) n (count children)]
              (doseq [[i ^File child] (map-indexed vector children)]
                (let [last? (= i (dec n)) branch (if last? "└── " "├── ") child-prefix (str prefix (if last? "    " "│   "))
                      name (.getName child) git-status (get git-info name) [gp gc] (if git-status (format-git git-status) [nil nil])]
                  (println (str (paint prefix TREE_LINES) (paint branch TREE_LINES) (tree-entry-label child include-hidden?) (if (and gp (not (str/blank? gp))) (str " " gc) "")))
                  (when (and (.isDirectory child) (not (:symlink? (bulk-file-stats child)))) (walk child child-prefix))))))]
    (walk root "")))

(defn pad-cell [colored plain width align]
  (let [pad (max 0 (- width (count plain))) spaces (apply str (repeat pad \space))]
    (if (= align :left) (str colored spaces) (str spaces colored))))

(defn horizontal-border [widths kind]
  (let [[start sep end] (case kind :top ["┌" "┬" "┐"] :middle ["├" "┼" "┤"] :bottom ["└" "┴" "┘"])]
    (paint (str start (str/join sep (map #(apply str (repeat (+ % 2) "─")) widths)) end) BORDER)))

(defn render-row [columns widths]
  (str (paint "│" BORDER) (apply str (map (fn [[plain colored align] width] (str " " (pad-cell colored plain width align) " " (paint "│" BORDER))) columns widths))))

;; ---------------------------------------------------------------------
;; Adaptive column layout
;; ---------------------------------------------------------------------

(def BASE_COLS [:index :name :type :size :modified])
(def LONG_EXTRA_COLS [:usr :grp :oth :link])
(def DROPPABLE_ORDER [:link :oth :grp :usr :modified :size :type])

(defn col-header [id] (case id :index "#" :name "name" :type "type" :size "size" :modified "modified" :usr "usr" :grp "grp" :oth "oth" :link "link"))
(defn col-align [id] (case id :index :right :size :right :left))

(defn col-natural-width [id rows]
  (max (count (col-header id))
       (if (seq rows)
         (case id
           :index (count (str (max 0 (dec (count rows)))))
           :name (apply max (map #(count (:name-with-git-plain %)) rows))
           :type (apply max (map #(count (:type-plain %)) rows))
           :size (apply max (map #(count (:size-plain %)) rows))
           :modified (apply max (map #(count (:modified-plain %)) rows))
           (:usr :grp :oth) 3
           :link (apply max (map #(if-let [t (:link-target %)] (+ 3 (count t)) 1) rows)))
         1)))

(defn build-link-cell [target width]
  (if (nil? target) ["-" (paint "-" PERMS_NONE)]
      (let [full (str "-> " target)]
        (if (<= (count full) width) [full (str (paint "->" SYMLINK_ARROW) " " (paint target SYMLINK))]
            (let [avail (max 0 (- width 4)) trunc (if (pos? avail) (subs target 0 (min avail (count target))) "")]
              [(str "-> " trunc "…") (str (paint "->" SYMLINK_ARROW) " " (paint (str trunc "…") SYMLINK))])))))

(defn cell-for [id row width]
  (case id :index [(:idx-plain row) (:idx-colored row) (col-align id)] :name [(:name-with-git-plain row) (:name-with-git-colored row) (col-align id)]
           :type [(:type-plain row) (:type-colored row) (col-align id)] :size [(:size-plain row) (:size-colored row) (col-align id)]
           :modified [(:modified-plain row) (:modified-colored row) (col-align id)] :usr [(:user-perm-plain row) (:user-perm-colored row) (col-align id)]
           :grp [(:group-perm-plain row) (:group-perm-colored row) (col-align id)] :oth [(:other-perm-plain row) (:other-perm-colored row) (col-align id)]
           :link (let [[p c] (build-link-cell (:link-target row) width)] [p c (col-align id)])))

(defn fit-columns [rows term-width long?]
  (let [full-order (into BASE_COLS (if long? LONG_EXTRA_COLS []))
        natural (into {} (map (fn [id] [id (col-natural-width id rows)]) full-order))]
    (loop [active full-order link-width (get natural :link)]
      (let [widths (mapv #(if (= % :link) link-width (get natural %)) active)
            total (if (empty? widths) 0 (+ 1 (* 3 (count widths)) (apply + widths)))]
        (if (<= total term-width) {:active active :widths widths}
            (cond (and (some #{:link} active) (> link-width 6)) (recur active (max 6 (- link-width (- total term-width))))
                  (some #{:link} active) (recur (vec (remove #{:link} active)) link-width)
                  :else (if-let [drop-id (first (filter (set active) DROPPABLE_ORDER))]
                          (recur (vec (remove #{drop-id} active)) link-width)
                          {:active active :widths widths})))))))

(defn render-table [rows long?]
  (let [term-width (terminal-width)
        rows (mapv (fn [i row] (assoc row :idx-plain (str i) :idx-colored (paint (str i) INDEX))) (range) rows)
        {:keys [active widths]} (fit-columns rows term-width long?)
        header-cells (mapv (fn [id] [(col-header id) (paint (col-header id) HEADER) (col-align id)]) active)]
    (println (horizontal-border widths :top)) (println (render-row header-cells widths)) (println (horizontal-border widths :middle))
    (doseq [row rows] (println (render-row (mapv #(cell-for %1 row %2) active widths) widths)))
    (println (horizontal-border widths :bottom))))

;; ---------------------------------------------------------------------
;; Main
;; ---------------------------------------------------------------------

(defn -main [args]
  (let [opts (parse-args args)]
    (when (:help opts) (print-help) (System/exit 0))
    (let [path (:path opts)]
      (if-not (fs/exists? path) (do (println (str (paint "error:" WARN) " cannot read " path)) (System/exit 1))
          (let [git-info (when (:git opts) (load-git-info path))]
            (if (:tree opts) (print-tree (File. (str path)) (:include-hidden opts) git-info)
                (render-table (collect-entries path (:include-hidden opts) (:sort-modified opts) (:reverse opts) git-info (:long opts)) (:long opts))))))))

(-main *command-line-args*)
