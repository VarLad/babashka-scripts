;; ---------------------------------------------------------------------

(defn -main [args]
  (let [opts (parse-args args)
        path (:path opts)]
    (if-not (fs/exists? path)
      (do (println (str (paint "error:" WARN) " cannot read " path))
          (System/exit 1))
      (let [git-info (when (:git opts) (load-git-info path))]
        (if (:tree opts)
          (print-tree (File. (str path)) (:include-hidden opts) git-info)
          (let [rows (collect-entries path (:include-hidden opts) (:sort-modified opts)
                                       (:reverse opts) git-info)]
            (render-table rows (:long opts))))))))

(-main *command-line-args*)

