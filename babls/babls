#!/usr/bin/env bb

(ns babls
  (:require [clojure.string :as str]
            [babashka.process :refer [process]]
            [babashka.fs :as fs])
  (:import [java.io File]
           [java.nio.file Files LinkOption]
           [java.nio.file.attribute PosixFileAttributes BasicFileAttributes PosixFilePermissions]
           [org.jline.terminal TerminalBuilder]))

;; ---------------------------------------------------------------------
;; Help
;; ---------------------------------------------------------------------

(def help-text
  "babls - a NuShell-inspired `ls` with color in Babashka.

Usage:
  babls [path] [-a] [-m] [-r] [-g] [-l] [-t]

Flags:
  -a / --all              include dotfiles
  -m / --sort-modified    sort by modified time, newest first
  -r / --reverse          reverse sort order
  -g / --git              show git status (+added/-deleted) if inside a repo
  -l / --long             show extra columns: owner/group/other perms + symlink target
  -t / --tree             print a tree view instead of a table (recursive)
  -h / --help             show this help message and exit
Short flags can be combined, e.g. -alr")

(defn print-help [] (println help-text))

