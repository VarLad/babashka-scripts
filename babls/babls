(def MODIFIED_HOURS "\u001b[38;5;184m")
(def MODIFIED_DAYS "\u001b[38;5;208m")
(def MODIFIED_WEEKS "\u001b[38;5;203m")
(def MODIFIED_OLD "\u001b[38;5;244m")
